-- get EXPLAIN output for all variations
\set PREFIX 'EXPLAIN (analyze, buffers off, costs off, timing off, summary off)'
SET work_mem TO '64MB';
SET enable_memoize TO on;
\set TEST_TABLE 'metrics'
\ir :TEST_QUERY_NAME
-- This file and its contents are licensed under the Timescale License.
-- Please see the included NOTICE for copyright information and
-- LICENSE-TIMESCALE for a copy of the license.
SHOW enable_memoize;
 enable_memoize 
----------------
 on

:PREFIX
SELECT m1.time, m2.time
FROM :TEST_TABLE m1
LEFT JOIN LATERAL (
    SELECT time FROM :TEST_TABLE m2
    WHERE m1.time + '0 seconds'::interval = m2.time
    LIMIT 1
) m2 ON true
ORDER BY m1.time;
--- QUERY PLAN ---
 Nested Loop Left Join (actual rows=68370.00 loops=1)
   ->  Custom Scan (ChunkAppend) on metrics m1 (actual rows=68370.00 loops=1)
         Order: m1."time"
         ->  Index Only Scan Backward using _hyper_1_1_chunk_metrics_time_idx on _hyper_1_1_chunk m1_1 (actual rows=17990.00 loops=1)
         ->  Index Only Scan Backward using _hyper_1_2_chunk_metrics_time_idx on _hyper_1_2_chunk m1_2 (actual rows=25190.00 loops=1)
         ->  Index Only Scan Backward using _hyper_1_3_chunk_metrics_time_idx on _hyper_1_3_chunk m1_3 (actual rows=25190.00 loops=1)
   ->  Memoize (actual rows=1.00 loops=68370)
         Cache Key: m1."time"
         Cache Mode: binary
         Hits: 54696  Misses: 13674  Evictions: 0  Overflows: 0 
         ->  Limit (actual rows=1.00 loops=13674)
               ->  Custom Scan (ChunkAppend) on metrics m2 (actual rows=1.00 loops=13674)
                     Chunks excluded during startup: 0
                     Chunks excluded during runtime: 2
                     ->  Index Only Scan using _hyper_1_1_chunk_metrics_time_idx on _hyper_1_1_chunk m2_1 (actual rows=1.00 loops=3598)
                           Index Cond: ("time" = (m1."time" + '@ 0'::interval))
                     ->  Index Only Scan using _hyper_1_2_chunk_metrics_time_idx on _hyper_1_2_chunk m2_2 (actual rows=1.00 loops=5038)
                           Index Cond: ("time" = (m1."time" + '@ 0'::interval))
                     ->  Index Only Scan using _hyper_1_3_chunk_metrics_time_idx on _hyper_1_3_chunk m2_3 (actual rows=1.00 loops=5038)
                           Index Cond: ("time" = (m1."time" + '@ 0'::interval))

