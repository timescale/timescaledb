               ->  Custom Scan (ColumnarScan) on _hyper_1_1_chunk (actual rows=3572.00 loops=1)
                     Filter: (("time" > 'Fri Dec 31 17:00:00 1999 PST'::timestamp with time zone) OR (device_id = 1))
