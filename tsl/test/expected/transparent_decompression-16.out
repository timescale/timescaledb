-- test prepared statement with params pushdown
PREPARE param_prep (int) AS
SELECT *
FROM generate_series('2000-01-01'::timestamptz, '2000-02-01'::timestamptz, '1d'::interval) g (time)
        INNER JOIN LATERAL (
            SELECT time
            FROM :TEST_TABLE m1
            WHERE m1.time = g.time
                AND device_id = $1
            LIMIT 1) m1 ON TRUE;
:PREFIX EXECUTE param_prep (1);
--- QUERY PLAN ---
 Nested Loop (actual rows=19.00 loops=1)
   ->  Function Scan on generate_series g (actual rows=32.00 loops=1)
   ->  Limit (actual rows=1.00 loops=32)
         ->  Custom Scan (ChunkAppend) on metrics_space m1 (actual rows=1.00 loops=32)
               Chunks excluded during runtime: 2
               ->  Custom Scan (ColumnarScan) on _hyper_2_4_chunk m1_1 (actual rows=1.00 loops=5)
                     Filter: ("time" = g."time")
                     Rows Removed by Filter: 336
                     ->  Seq Scan on _hyper_2_4_chunk_compressed (actual rows=1.00 loops=5)
                           Filter: ((_ts_meta_min_3 <= g."time") AND (_ts_meta_max_3 >= g."time") AND (device_id = 1))
               ->  Index Only Scan using _hyper_2_7_chunk_metrics_space_device_id_time_idx on _hyper_2_7_chunk m1_2 (actual rows=1.00 loops=7)
                     Index Cond: ((device_id = 1) AND ("time" = g."time"))
               ->  Custom Scan (ColumnarScan) on _hyper_2_10_chunk m1_3 (actual rows=1.00 loops=7)
                     Filter: ("time" = g."time")
                     Rows Removed by Filter: 160
                     ->  Seq Scan on _hyper_2_10_chunk_compressed (actual rows=1.00 loops=7)
                           Filter: ((_ts_meta_min_3 <= g."time") AND (_ts_meta_max_3 >= g."time") AND (device_id = 1))

:PREFIX EXECUTE param_prep (2);
--- QUERY PLAN ---
 Nested Loop (actual rows=19.00 loops=1)
   ->  Function Scan on generate_series g (actual rows=32.00 loops=1)
   ->  Limit (actual rows=1.00 loops=32)
