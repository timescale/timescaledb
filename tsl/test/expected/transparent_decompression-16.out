-- These plans are flaky between MergeAppend and Sort over Append.
SET enable_sort TO OFF;
--use the peer index
:PREFIX_VERBOSE
SELECT *
FROM :TEST_TABLE
WHERE device_id_peer = 1
ORDER BY device_id_peer,
    time;
