SET work_mem TO '50MB';
-- for ordered append tests on compressed chunks we need a hypertable with time as compress_orderby column
CREATE TABLE metrics_ordered(time timestamptz NOT NULL, device_id int, device_id_peer int, v0 int, v1 int, v2 float, v3 float);
SELECT create_hypertable('metrics_ordered','time');
       create_hypertable       
-------------------------------
 (11,public,metrics_ordered,t)

ALTER TABLE metrics_ordered SET (timescaledb.compress, timescaledb.compress_orderby='time DESC',timescaledb.compress_segmentby='device_id,device_id_peer');
INSERT INTO metrics_ordered SELECT * FROM metrics;
CREATE INDEX ON metrics_ordered(device_id,device_id_peer,time);
CREATE INDEX ON metrics_ordered(device_id,time);
CREATE INDEX ON metrics_ordered(device_id_peer,time);
-- compress all chunks
SELECT count(compress_chunk(ch)) FROM show_chunks('metrics_ordered') ch;
 count 
-------
     3

VACUUM ANALYZE metrics_ordered;
-- should not have ordered DecompressChunk path because segmentby columns are not part of pathkeys
:PREFIX SELECT * FROM metrics_ordered ORDER BY time DESC LIMIT 10;
--- QUERY PLAN ---
 Limit (actual rows=10.00 loops=1)
   ->  Custom Scan (ChunkAppend) on metrics_ordered (actual rows=10.00 loops=1)
         Order: metrics_ordered."time" DESC
         ->  Custom Scan (ColumnarScan) on _hyper_11_21_chunk (actual rows=10.00 loops=1)
               ->  Sort (actual rows=5.00 loops=1)
                     Sort Key: _hyper_11_21_chunk_compressed._ts_meta_v2_first_time DESC
                     Sort Method: quicksort 
                     ->  Seq Scan on _hyper_11_21_chunk_compressed (actual rows=5.00 loops=1)
         ->  Custom Scan (ColumnarScan) on _hyper_11_20_chunk (never executed)
               ->  Sort (never executed)
                     Sort Key: _hyper_11_20_chunk_compressed._ts_meta_v2_first_time DESC
                     ->  Seq Scan on _hyper_11_20_chunk_compressed (never executed)
         ->  Custom Scan (ColumnarScan) on _hyper_11_19_chunk (never executed)
               ->  Sort (never executed)
                     Sort Key: _hyper_11_19_chunk_compressed._ts_meta_v2_first_time DESC
                     ->  Seq Scan on _hyper_11_19_chunk_compressed (never executed)

-- should have ordered DecompressChunk path because segmentby columns have equality constraints
:PREFIX SELECT * FROM metrics_ordered WHERE device_id = 1 AND device_id_peer = 3 ORDER BY time DESC LIMIT 10;
--- QUERY PLAN ---
 Limit (actual rows=0.00 loops=1)
   ->  Custom Scan (ChunkAppend) on metrics_ordered (actual rows=0.00 loops=1)
         Order: metrics_ordered."time" DESC
         ->  Custom Scan (ColumnarScan) on _hyper_11_21_chunk (actual rows=0.00 loops=1)
               ->  Sort (actual rows=0.00 loops=1)
                     Sort Key: _hyper_11_21_chunk_compressed._ts_meta_v2_first_time DESC, _hyper_11_21_chunk_compressed._ts_meta_v2_last_time DESC
                     Sort Method: quicksort 
                     ->  Seq Scan on _hyper_11_21_chunk_compressed (actual rows=0.00 loops=1)
                           Filter: ((device_id = 1) AND (device_id_peer = 3))
                           Rows Removed by Filter: 5
         ->  Custom Scan (ColumnarScan) on _hyper_11_20_chunk (actual rows=0.00 loops=1)
               ->  Sort (actual rows=0.00 loops=1)
                     Sort Key: _hyper_11_20_chunk_compressed._ts_meta_v2_first_time DESC, _hyper_11_20_chunk_compressed._ts_meta_v2_last_time DESC
                     Sort Method: quicksort 
                     ->  Seq Scan on _hyper_11_20_chunk_compressed (actual rows=0.00 loops=1)
                           Filter: ((device_id = 1) AND (device_id_peer = 3))
                           Rows Removed by Filter: 5
         ->  Custom Scan (ColumnarScan) on _hyper_11_19_chunk (actual rows=0.00 loops=1)
               ->  Sort (actual rows=0.00 loops=1)
                     Sort Key: _hyper_11_19_chunk_compressed._ts_meta_v2_first_time DESC, _hyper_11_19_chunk_compressed._ts_meta_v2_last_time DESC
                     Sort Method: quicksort 
                     ->  Seq Scan on _hyper_11_19_chunk_compressed (actual rows=0.00 loops=1)
                           Filter: ((device_id = 1) AND (device_id_peer = 3))
                           Rows Removed by Filter: 5

:PREFIX SELECT DISTINCT ON (d.device_id) * FROM metrics_ordered d INNER JOIN LATERAL (SELECT * FROM metrics_ordered m WHERE m.device_id=d.device_id AND m.device_id_peer = 3 ORDER BY time DESC LIMIT 1 ) m ON true;
--- QUERY PLAN ---
 Unique (actual rows=0.00 loops=1)
