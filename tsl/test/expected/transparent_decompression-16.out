-- test targetlist not referencing columns
:PREFIX
SELECT 1
FROM :TEST_TABLE;
--- QUERY PLAN ---
 Result (actual rows=8640.00 loops=1)
   ->  Append (actual rows=8640.00 loops=1)
         ->  Custom Scan (ColumnarScan) on _hyper_1_1_chunk (actual rows=3600.00 loops=1)
               ->  Seq Scan on _hyper_1_1_chunk_compressed (actual rows=5.00 loops=1)
         ->  Seq Scan on _hyper_1_2_chunk (actual rows=3360.00 loops=1)
