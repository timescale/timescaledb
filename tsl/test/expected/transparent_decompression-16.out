                     ->  Seq Scan on _hyper_2_10_chunk_compressed (actual rows=1.00 loops=1)
                           Filter: (device_id = 1)
         ->  Index Scan using _hyper_2_7_chunk_metrics_space_time_idx on _hyper_2_7_chunk (never executed)
               Filter: (device_id = 1)
         ->  Sort (never executed)
               Sort Key: _hyper_2_4_chunk."time" DESC
               ->  Custom Scan (ColumnarScan) on _hyper_2_4_chunk (never executed)
                     ->  Seq Scan on _hyper_2_4_chunk_compressed (never executed)
                           Filter: (device_id = 1)

DROP VIEW compressed_view;
