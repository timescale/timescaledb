SELECT
       format('include/%s_query.sql', :'TEST_BASE_NAME') as "TEST_QUERY_NAME",
       format('%s/results/%s_results_unmemoized.out', :'TEST_OUTPUT_DIR', :'TEST_BASE_NAME') as "TEST_RESULTS_UNMEMOIZED",
       format('%s/results/%s_results_memoized.out', :'TEST_OUTPUT_DIR', :'TEST_BASE_NAME') as "TEST_RESULTS_MEMOIZED"
\gset
SELECT format('\! diff -u --label "Unmemoized results" --label "Memoized results" %s %s', :'TEST_RESULTS_UNMEMOIZED', :'TEST_RESULTS_MEMOIZED') as "DIFF_CMD"
\gset
-- create normal hypertable with dropped columns, each chunk will have different attribute numbers
CREATE TABLE metrics(time timestamptz NOT NULL, device_id int, v0 int, v1 int, v2 float, v3 float);
SELECT create_hypertable('metrics','time',create_default_indexes:=false);
  create_hypertable   
----------------------
 (1,public,metrics,t)

INSERT INTO metrics(time,device_id,v0,v1,v2,v3) SELECT time, device_id, device_id+1,  device_id + 2, device_id + 0.5, NULL FROM generate_series('2000-01-01 0:00:00+0'::timestamptz,'2000-01-05 23:55:00+0','10m') time, generate_series(1,27) device_id;
INSERT INTO metrics(time,device_id,v0,v1,v2,v3) SELECT time, device_id, device_id-1, device_id + 2, device_id + 0.5, NULL FROM generate_series('2000-01-06 0:00:00+0'::timestamptz,'2000-01-12 23:55:00+0','10m') time, generate_series(1,27) device_id;
INSERT INTO metrics(time,device_id,v0,v1,v2,v3) SELECT time, device_id, device_id, device_id + 2, device_id + 0.5, NULL FROM generate_series('2000-01-13 0:00:00+0'::timestamptz,'2000-01-19 23:55:00+0','10m') time, generate_series(1,27) device_id;
CREATE INDEX ON metrics(time DESC);
CREATE INDEX ON metrics(device_id,time DESC);
VACUUM FULL ANALYZE metrics;
-- create identical hypertable with space partitioning
CREATE TABLE metrics_space(time timestamptz NOT NULL, device_id int, v0 int, v1 int, v2 float, v3 float);
SELECT create_hypertable('metrics_space','time','device_id',3,create_default_indexes:=false);
     create_hypertable      
----------------------------
 (2,public,metrics_space,t)

INSERT INTO metrics_space SELECT * FROM metrics;
CREATE INDEX ON metrics_space(time);
CREATE INDEX ON metrics_space(device_id,time);
VACUUM FULL ANALYZE metrics_space;
-- create hypertable with compression
CREATE TABLE metrics_compressed(time timestamptz NOT NULL, device_id int, v0 int, v1 int, v2 float, v3 float);
SELECT create_hypertable('metrics_compressed','time',create_default_indexes:=false);
        create_hypertable        
---------------------------------
 (3,public,metrics_compressed,t)

INSERT INTO metrics_compressed SELECT * FROM metrics;
CREATE INDEX ON metrics_compressed(time);
CREATE INDEX ON metrics_compressed(device_id,time);
-- compress chunks
ALTER TABLE metrics_compressed SET (timescaledb.compress, timescaledb.compress_orderby='time DESC', timescaledb.compress_segmentby='device_id');
SELECT compress_chunk(show_chunks('metrics_compressed'));
             compress_chunk              
-----------------------------------------
 _timescaledb_internal._hyper_3_13_chunk
 _timescaledb_internal._hyper_3_14_chunk
 _timescaledb_internal._hyper_3_15_chunk

UPDATE metrics_compressed SET v3 = 42 WHERE device_id=1 AND time > '2000-01-01' AND time < '2000-01-02';
VACUUM FULL ANALYZE metrics_compressed;
-- create hypertable with space partitioning and compression
CREATE TABLE metrics_space_compressed(time timestamptz NOT NULL, device_id int, v0 int, v1 int, v2 float, v3 float);
SELECT create_hypertable('metrics_space_compressed','time','device_id',3,create_default_indexes:=false);
           create_hypertable           
---------------------------------------
 (5,public,metrics_space_compressed,t)

INSERT INTO metrics_space_compressed SELECT * FROM metrics;
CREATE INDEX ON metrics_space_compressed(time);
CREATE INDEX ON metrics_space_compressed(device_id,time);
ANALYZE metrics_space_compressed;
-- compress chunks
ALTER TABLE metrics_space_compressed SET (timescaledb.compress, timescaledb.compress_orderby='time DESC', timescaledb.compress_segmentby='device_id');
SELECT compress_chunk(show_chunks('metrics_space_compressed'));
             compress_chunk              
-----------------------------------------
 _timescaledb_internal._hyper_5_16_chunk
 _timescaledb_internal._hyper_5_17_chunk
 _timescaledb_internal._hyper_5_18_chunk
 _timescaledb_internal._hyper_5_19_chunk
 _timescaledb_internal._hyper_5_20_chunk
 _timescaledb_internal._hyper_5_21_chunk
 _timescaledb_internal._hyper_5_22_chunk
 _timescaledb_internal._hyper_5_23_chunk
 _timescaledb_internal._hyper_5_24_chunk

VACUUM FULL ANALYZE metrics_space_compressed;
-- get EXPLAIN output for all variations
\set PREFIX 'EXPLAIN (analyze, buffers off, costs off, timing off, summary off)'
SET work_mem TO '64MB';
SET enable_memoize TO on;
\set TEST_TABLE 'metrics'
\ir :TEST_QUERY_NAME
-- This file and its contents are licensed under the Timescale License.
-- Please see the included NOTICE for copyright information and
-- LICENSE-TIMESCALE for a copy of the license.
SHOW enable_memoize;
 enable_memoize 
----------------
 on

:PREFIX
SELECT m1.time, m2.time
FROM :TEST_TABLE m1
LEFT JOIN LATERAL (
    SELECT time FROM :TEST_TABLE m2
    WHERE m1.device_id = m2.device_id
    ORDER BY m2.time DESC
    LIMIT 1
) m2 ON true
ORDER BY m1.time
LIMIT 10000
;
--- QUERY PLAN ---
 Limit (actual rows=10000.00 loops=1)
   ->  Nested Loop Left Join (actual rows=10000.00 loops=1)
         ->  Custom Scan (ChunkAppend) on metrics m1 (actual rows=10000.00 loops=1)
               Order: m1."time"
               ->  Index Scan Backward using _hyper_1_1_chunk_metrics_time_idx on _hyper_1_1_chunk m1_1 (actual rows=10000.00 loops=1)
               ->  Index Scan Backward using _hyper_1_2_chunk_metrics_time_idx on _hyper_1_2_chunk m1_2 (never executed)
               ->  Index Scan Backward using _hyper_1_3_chunk_metrics_time_idx on _hyper_1_3_chunk m1_3 (never executed)
         ->  Memoize (actual rows=1.00 loops=10000)
               Cache Key: m1.device_id
               Cache Mode: binary
               Hits: 9973  Misses: 27  Evictions: 0  Overflows: 0 
               ->  Limit (actual rows=1.00 loops=27)
                     ->  Custom Scan (ChunkAppend) on metrics m2 (actual rows=1.00 loops=27)
                           Order: m2."time" DESC
                           Hypertables excluded during runtime: 0
                           ->  Index Only Scan using _hyper_1_3_chunk_metrics_device_id_time_idx on _hyper_1_3_chunk m2_1 (actual rows=1.00 loops=27)
                                 Index Cond: (device_id = m1.device_id)
                           ->  Index Only Scan using _hyper_1_2_chunk_metrics_device_id_time_idx on _hyper_1_2_chunk m2_2 (never executed)
                                 Index Cond: (device_id = m1.device_id)
                           ->  Index Only Scan using _hyper_1_1_chunk_metrics_device_id_time_idx on _hyper_1_1_chunk m2_3 (never executed)
                                 Index Cond: (device_id = m1.device_id)

