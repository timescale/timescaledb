-- Timestamp uses minmax
explain (analyze, verbose, buffers off, costs off, timing off, summary off)
select count(*) from test_sparse_index where ts between '2021-01-07' and '2021-01-14';
--- QUERY PLAN ---
 Finalize Aggregate (actual rows=1.00 loops=1)
   Output: count(*)
   ->  Custom Scan (VectorAgg) (actual rows=1.00 loops=1)
         Output: (PARTIAL count(*))
         Grouping Policy: all compressed batches
         ->  Custom Scan (ColumnarScan) on _timescaledb_internal._hyper_3_2_chunk (actual rows=169.00 loops=1)
               Vectorized Filter: ((_hyper_3_2_chunk.ts >= 'Thu Jan 07 00:00:00 2021'::timestamp without time zone) AND (_hyper_3_2_chunk.ts <= 'Thu Jan 14 00:00:00 2021'::timestamp without time zone))
               Rows Removed by Filter: 831
               Bulk Decompression: true
               ->  Seq Scan on _timescaledb_internal._hyper_3_2_chunk_compressed (actual rows=1.00 loops=1)
                     Output: _hyper_3_2_chunk_compressed._ts_meta_count, _hyper_3_2_chunk_compressed._ts_meta_min_1, _hyper_3_2_chunk_compressed._ts_meta_max_1, _hyper_3_2_chunk_compressed._ts_meta_v2_first_x, _hyper_3_2_chunk_compressed._ts_meta_v2_last_x, _hyper_3_2_chunk_compressed.x, _hyper_3_2_chunk_compressed.value, _hyper_3_2_chunk_compressed.regress-test-bloom_u, _hyper_3_2_chunk_compressed.u, _hyper_3_2_chunk_compressed._ts_meta_v2_min_ts, _hyper_3_2_chunk_compressed._ts_meta_v2_max_ts, _hyper_3_2_chunk_compressed.ts
                     Filter: ((_hyper_3_2_chunk_compressed._ts_meta_v2_max_ts >= 'Thu Jan 07 00:00:00 2021'::timestamp without time zone) AND (_hyper_3_2_chunk_compressed._ts_meta_v2_min_ts <= 'Thu Jan 14 00:00:00 2021'::timestamp without time zone))
                     Rows Removed by Filter: 9

