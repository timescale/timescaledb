-- Some primitive tests that show cost of DecompressChunk node so that we can
-- monitor the changes.
create table costtab(ts int, s text, c text, ti text, fi float);
select create_hypertable('costtab', 'ts');
  create_hypertable   
----------------------
 (1,public,costtab,t)

alter table costtab set (timescaledb.compress, timescaledb.compress_segmentby = 's',
    timescaledb.compress_orderby = 'ts');
insert into costtab select ts, ts % 10, ts::text, ts::text, ts::float from generate_series(1, 10000) ts;
create index on costtab(ti);
create index on costtab(fi);
select count(compress_chunk(x)) from show_chunks('costtab') x;
 count 
-------
     1

vacuum freeze analyze costtab;
explain (buffers off) select * from costtab;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_1_1_chunk  (cost=10.11..101.10 rows=10000 width=108)
   ->  Seq Scan on _hyper_1_1_chunk_compressed  (cost=0.00..1.10 rows=10 width=142)

set timescaledb.enable_bulk_decompression to off;
explain (buffers off) select * from costtab;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_1_1_chunk  (cost=0.11..1001.10 rows=10000 width=108)
   ->  Seq Scan on _hyper_1_1_chunk_compressed  (cost=0.00..1.10 rows=10 width=142)

reset timescaledb.enable_bulk_decompression;
explain (buffers off) select * from costtab where s = '1';
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_1_1_chunk  (cost=11.12..11.12 rows=1000 width=108)
   ->  Seq Scan on _hyper_1_1_chunk_compressed  (cost=0.00..1.12 rows=1 width=142)
         Filter: (s = '1'::text)

explain (buffers off) select * from costtab where c = '100';
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_1_1_chunk  (cost=10.11..101.10 rows=10000 width=108)
   Vectorized Filter: (c = '100'::text)
   ->  Seq Scan on _hyper_1_1_chunk_compressed  (cost=0.00..1.10 rows=10 width=142)

explain (buffers off) select * from costtab where ti = '200';
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_1_1_chunk  (cost=10.38..31.12 rows=3000 width=108)
   Vectorized Filter: (ti = '200'::text)
   ->  Seq Scan on _hyper_1_1_chunk_compressed  (cost=0.00..1.12 rows=3 width=142)
         Filter: _timescaledb_functions.bloom1_contains_any_hashes(regress-test-bloom_ti, TEST-HASHES::bigint[])

explain (buffers off) select * from costtab where fi = 200;
--- QUERY PLAN ---
