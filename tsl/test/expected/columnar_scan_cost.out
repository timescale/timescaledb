vacuum analyze estimate_count;
\c :TEST_DBNAME :ROLE_SUPERUSER
with chunks as (
    select (schema_name || '.' || table_name)::regclass as relid
    from _timescaledb_catalog.chunk
    where hypertable_id = (
        select id
        from _timescaledb_catalog.hypertable
        where (schema_name || '.' || table_name)::regclass = 'estimate_count'::regclass)
)
delete from pg_statistic
where starelid in (
    select relid from chunks
    union all
    select cs.compress_relid
    from _timescaledb_catalog.compression_settings cs
    join chunks on cs.relid = chunks.relid
)
;
explain (analyze, timing off, summary off, buffers off) select * from estimate_count;
--- QUERY PLAN ---
 Append  (cost=10.04..45123.00 rows=3000000 width=20) (actual rows=289500.00 loops=1)
   ->  Custom Scan (ColumnarScan) on _hyper_3_11_chunk  (cost=10.04..15061.00 rows=1500000 width=20) (actual rows=96000.00 loops=1)
         ->  Seq Scan on _hyper_3_11_chunk_compressed  (cost=0.00..61.00 rows=1500 width=88) (actual rows=1500.00 loops=1)
   ->  Custom Scan (ColumnarScan) on _hyper_3_12_chunk  (cost=10.04..15062.00 rows=1500000 width=20) (actual rows=193500.00 loops=1)
         ->  Seq Scan on _hyper_3_12_chunk_compressed  (cost=0.00..62.00 rows=1500 width=88) (actual rows=1500.00 loops=1)

-- Test a high-cardinality orderby column
create table highcard(ts int) with (tsdb.hypertable, tsdb.partition_column = 'ts',
    tsdb.compress_orderby = 'ts', tsdb.chunk_interval = 10000000);
insert into highcard select generate_series(1, 1000000);
select count(compress_chunk(x)) from show_chunks('highcard') x;
 count 
-------
     1

vacuum freeze analyze highcard;
explain (buffers off, analyze, timing off, summary off)
select * from highcard where ts > 200000 and ts < 300000;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_5_13_chunk  (cost=10.43..1006.02 rows=99000 width=4) (actual rows=99999.00 loops=1)
   Vectorized Filter: ((ts > 200000) AND (ts < 300000))
   Rows Removed by Filter: 1
   ->  Index Scan using _hyper_5_13_chunk_compressed__ts_meta_v2_first_ts__ts_meta__idx on _hyper_5_13_chunk_compressed  (cost=0.28..16.02 rows=99 width=44) (actual rows=100.00 loops=1)
         Index Cond: ((_ts_meta_v2_first_ts < 300000) AND (_ts_meta_v2_last_ts > 200000))

explain (buffers off, analyze, timing off, summary off)
select * from highcard where ts = 500000;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_5_13_chunk  (cost=29.14..29.14 rows=1000 width=4) (actual rows=1.00 loops=1)
   Vectorized Filter: (ts = 500000)
   Rows Removed by Filter: 999
   ->  Index Scan using _hyper_5_13_chunk_compressed__ts_meta_v2_first_ts__ts_meta__idx on _hyper_5_13_chunk_compressed  (cost=0.28..19.14 rows=1 width=44) (actual rows=1.00 loops=1)
         Index Cond: ((_ts_meta_v2_first_ts <= 500000) AND (_ts_meta_v2_last_ts >= 500000))

explain (buffers off, analyze, timing off, summary off)
select * from highcard where ts < 500000;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_5_13_chunk  (cost=10.32..5002.05 rows=498000 width=4) (actual rows=499999.00 loops=1)
   Vectorized Filter: (ts < 500000)
   Rows Removed by Filter: 1
   ->  Index Scan using _hyper_5_13_chunk_compressed__ts_meta_v2_first_ts__ts_meta__idx on _hyper_5_13_chunk_compressed  (cost=0.28..22.05 rows=498 width=44) (actual rows=500.00 loops=1)
         Index Cond: (_ts_meta_v2_first_ts < 500000)

explain (buffers off, analyze, timing off, summary off)
select * from highcard where ts > 500000;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_5_13_chunk  (cost=10.05..5036.50 rows=501000 width=4) (actual rows=500000.00 loops=1)
   Vectorized Filter: (ts > 500000)
   ->  Seq Scan on _hyper_5_13_chunk_compressed  (cost=0.00..26.50 rows=501 width=44) (actual rows=500.00 loops=1)
         Filter: (_ts_meta_v2_last_ts > 500000)
         Rows Removed by Filter: 500

-- Test for an OOB write we used to have where the max metadata column is the
-- last column in the compressed chunk table, as can happen on old versions.
create table lastmax(ts int) with (tsdb.hypertable, tsdb.partition_column = 'ts',
    tsdb.compress_orderby = 'ts');
insert into lastmax select generate_series(1, 1000);
select count(compress_chunk(x)) from show_chunks('lastmax') x;
 count 
-------
     1

vacuum freeze analyze lastmax;
select cs.compress_relid::regclass chunk, 'c' column from _timescaledb_catalog.chunk ch
    join _timescaledb_catalog.compression_settings cs
        on cs.relid = format('%I.%I', ch.schema_name, ch.table_name)::regclass
    where ch.hypertable_id = (select id from _timescaledb_catalog.hypertable
        where table_name = 'lastmax') limit 1
\gset
set timescaledb.restoring to true;
alter table :chunk drop column _ts_meta_max_1;
alter table :chunk add column _ts_meta_max_1 int default 1000;
reset timescaledb.restoring;
explain (costs off)
select * from lastmax where ts = 500;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_7_14_chunk
   Vectorized Filter: (ts = 500)
   ->  Seq Scan on _hyper_7_14_chunk_compressed
         Filter: ((_ts_meta_v2_first_ts <= 500) AND (_ts_meta_v2_last_ts >= 500))

