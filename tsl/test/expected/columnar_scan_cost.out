explain (buffers off) select * from costtab where ts = 5000;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_1_1_chunk  (cost=11.15..11.15 rows=1000 width=108)
   Vectorized Filter: (ts = 5000)
   ->  Seq Scan on _hyper_1_1_chunk_compressed  (cost=0.00..1.15 rows=1 width=142)
         Filter: ((_ts_meta_v2_first_ts <= 5000) AND (_ts_meta_v2_last_ts >= 5000))

explain (buffers off) select * from costtab where fi = 200 and ts = 5000;
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_1_1_chunk  (cost=11.20..11.20 rows=1000 width=108)
   Vectorized Filter: ((fi = '200'::double precision) AND (ts = 5000))
   ->  Seq Scan on _hyper_1_1_chunk_compressed  (cost=0.00..1.20 rows=1 width=142)
         Filter: ((_ts_meta_v2_min_fi <= '200'::double precision) AND (_ts_meta_v2_max_fi >= '200'::double precision) AND (_ts_meta_v2_first_ts <= 5000) AND (_ts_meta_v2_last_ts >= 5000))

explain (buffers off) select * from costtab where s = '1' or (fi = 200 and ts = 5000);
--- QUERY PLAN ---
 Custom Scan (ColumnarScan) on _hyper_1_1_chunk  (cost=11.22..11.22 rows=1000 width=108)
   Filter: ((s = '1'::text) OR ((fi = '200'::double precision) AND (ts = 5000)))
   ->  Seq Scan on _hyper_1_1_chunk_compressed  (cost=0.00..1.23 rows=1 width=142)
         Filter: ((s = '1'::text) OR ((_ts_meta_v2_min_fi <= '200'::double precision) AND (_ts_meta_v2_max_fi >= '200'::double precision) AND (_ts_meta_v2_first_ts <= 5000) AND (_ts_meta_v2_last_ts >= 5000)))

-- Test estimation of compressed batch size using the _ts_meta_count stats.
create table estimate_count(time timestamptz, device int, value float);
select create_hypertable('estimate_count','time');
      create_hypertable      
-----------------------------
 (3,public,estimate_count,t)

alter table estimate_count
  set (timescaledb.compress,
       timescaledb.compress_segmentby = 'device',
       timescaledb.compress_orderby   = 'time');
-- same batch sizes
insert into estimate_count
select t, d, 1
from generate_series('2025-01-01'::timestamptz,'2025-01-03','15 min') t,
  generate_series(1, 1500) d
;
select count(compress_chunk(c)) from show_chunks('estimate_count') c;
 count 
-------
     2

vacuum analyze estimate_count;
explain (analyze, timing off, summary off, buffers off) select * from estimate_count;
--- QUERY PLAN ---
 Append  (cost=0.68..4465.50 rows=289500 width=20) (actual rows=289500.00 loops=1)
   ->  Custom Scan (ColumnarScan) on _hyper_3_2_chunk  (cost=0.68..1021.00 rows=96000 width=20) (actual rows=96000.00 loops=1)
         ->  Seq Scan on _hyper_3_2_chunk_compressed  (cost=0.00..61.00 rows=1500 width=88) (actual rows=1500.00 loops=1)
   ->  Custom Scan (ColumnarScan) on _hyper_3_3_chunk  (cost=1.33..1997.00 rows=193500 width=20) (actual rows=193500.00 loops=1)
         ->  Seq Scan on _hyper_3_3_chunk_compressed  (cost=0.00..62.00 rows=1500 width=88) (actual rows=1500.00 loops=1)

-- different batch sizes
truncate estimate_count;
insert into estimate_count
select t, d, 2
from generate_series(1, 1500) d,
    lateral generate_series('2025-01-01'::timestamptz,'2025-01-03',
        interval '15 min' * (d % 10 + 1)) t
;
select count(compress_chunk(c)) from show_chunks('estimate_count') c;
 count 
-------
     2

vacuum analyze estimate_count;
explain (analyze, timing off, summary off, buffers off) select * from estimate_count;
--- QUERY PLAN ---
 Append  (cost=0.23..1406.75 rows=85650 width=20) (actual rows=85650.00 loops=1)
   ->  Custom Scan (ColumnarScan) on _hyper_3_4_chunk  (cost=0.23..347.50 rows=28650 width=20) (actual rows=28650.00 loops=1)
         ->  Seq Scan on _hyper_3_4_chunk_compressed  (cost=0.00..61.00 rows=1500 width=88) (actual rows=1500.00 loops=1)
   ->  Custom Scan (ColumnarScan) on _hyper_3_5_chunk  (cost=0.42..631.00 rows=57000 width=20) (actual rows=57000.00 loops=1)
         ->  Seq Scan on _hyper_3_5_chunk_compressed  (cost=0.00..61.00 rows=1500 width=88) (actual rows=1500.00 loops=1)

-- more different batch sizes
truncate estimate_count;
insert into estimate_count
select t, d, 2
from generate_series(1, 1500) d,
    lateral generate_series('2025-01-01'::timestamptz,'2025-01-03',
        interval '15 min' + interval '1 minute' * d) t
;
select count(compress_chunk(c)) from show_chunks('estimate_count') c;
 count 
-------
     2

vacuum analyze estimate_count;
explain (analyze, timing off, summary off, buffers off) select * from estimate_count;
--- QUERY PLAN ---
 Append  (cost=0.07..329.59 rows=13973 width=20) (actual rows=13984.00 loops=1)
   ->  Custom Scan (ColumnarScan) on _hyper_3_6_chunk  (cost=0.07..110.50 rows=5050 width=20) (actual rows=5053.00 loops=1)
