         Sort Key: _hyper_1_11_chunk_compressed._ts_meta_v2_first_time, _hyper_1_11_chunk_compressed._ts_meta_v2_last_time
         ->  Seq Scan on _timescaledb_internal._hyper_1_11_chunk_compressed
               Output: _hyper_1_11_chunk_compressed._ts_meta_count, _hyper_1_11_chunk_compressed.device_id, _hyper_1_11_chunk_compressed._ts_meta_min_1, _hyper_1_11_chunk_compressed._ts_meta_max_1, _hyper_1_11_chunk_compressed._ts_meta_v2_first_time, _hyper_1_11_chunk_compressed._ts_meta_v2_last_time, _hyper_1_11_chunk_compressed."time", _hyper_1_11_chunk_compressed.val
