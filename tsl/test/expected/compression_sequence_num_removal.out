SET ROLE :ROLE_DEFAULT_PERM_USER;
DROP TABLE hyper;
-- Test type coercion during metadata EquivalenceClass creation
CREATE TABLE varchar(
    time INT NOT NULL,
    device_id varchar,
	text varchar,
    val INT);
SELECT * FROM create_hypertable('varchar', 'time', chunk_time_interval => 10);
