-- Error - invalid aggregate function
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('agg_test_cagg_mat', 'invalid_func(temperature) AS bad');
ERROR:  "invalid_func" is not an aggregate function
\set ON_ERROR_STOP 1
-- Error - aggregate already exists (same alias)
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('agg_test_cagg_mat', 'sum(temperature) AS sum_temp');
ERROR:  column "sum_temp" already exists in continuous aggregate
\set ON_ERROR_STOP 1
-- if_not_exists=true should not error
SELECT add_continuous_aggregate_column('agg_test_cagg_mat', 'sum(temperature) AS sum_temp', true);
NOTICE:  column "sum_temp" already exists in continuous aggregate, skipping
 add_continuous_aggregate_column 
---------------------------------
 

