-- Cleanup materialized-only hierarchical CAggs
DROP MATERIALIZED VIEW test_cagg_level3;
NOTICE:  drop cascades to table _timescaledb_internal._hyper_5_6_chunk
DROP MATERIALIZED VIEW test_cagg_level2;
NOTICE:  drop cascades to table _timescaledb_internal._hyper_4_5_chunk
-- Hierarchical continuous aggregate with real-time mode
-- Create a second-level real-time CAgg on top of test_cagg_realtime
CREATE MATERIALIZED VIEW test_cagg_realtime_level2
    WITH (timescaledb.continuous, timescaledb.materialized_only=false)
AS SELECT
    time_bucket('7 days', bucket) AS bucket,
    device_id,
    avg(avg_value) AS avg_value
FROM test_cagg_realtime
GROUP BY 1, 2
WITH NO DATA;
-- Create a third-level real-time CAgg on top of test_cagg_realtime_level2
CREATE MATERIALIZED VIEW test_cagg_realtime_level3
    WITH (timescaledb.continuous, timescaledb.materialized_only=false)
AS SELECT
    time_bucket('14 days', bucket) AS bucket,
    device_id,
    avg(avg_value) AS avg_value
FROM test_cagg_realtime_level2
GROUP BY 1, 2
WITH NO DATA;
-- Refresh all levels
CALL refresh_continuous_aggregate('test_cagg_realtime_level2', NULL, NULL);
CALL refresh_continuous_aggregate('test_cagg_realtime_level3', NULL, NULL);
-- Show initial state
SELECT * FROM test_cagg_realtime_level2 ORDER BY bucket, device_id;
            bucket            | device_id |    avg_value     
