\set EXPLAIN 'EXPLAIN (VERBOSE, BUFFERS OFF, COSTS OFF)'
SET timescaledb.enable_columnarindexscan TO OFF;
CREATE TABLE testtable (
time timestamptz NOT NULL,
segment_by_value integer,
int_value integer,
float_value double precision);
SELECT FROM create_hypertable(relation=>'testtable', time_column_name=> 'time');
--

ALTER TABLE testtable SET (timescaledb.compress, timescaledb.compress_segmentby='segment_by_value');
INSERT INTO testtable
SELECT time AS time,
value AS segment_by_value,
value AS int_value,
value AS float_value
FROM
generate_series('1980-01-01 00:00:00-00', '1980-03-01 00:00:00-00', INTERVAL '1 day') AS g1(time),
generate_series(-10, 100, 1) AS g2(value)
ORDER BY time;
-- Aggregation result without any vectorization
SELECT sum(segment_by_value), sum(int_value), sum(float_value) FROM testtable;
  sum   |  sum   |  sum   
--------+--------+--------
 304695 | 304695 | 304695

--
-- Enable this GUC to run this test with Hypercore TAM. The EXPLAINs
-- will differ, but the results should not.
--
--SET timescaledb.default_hypercore_use_access_method = true;
---
-- Tests with some chunks compressed
---
SELECT compress_chunk(ch) FROM show_chunks('testtable') ch LIMIT 3;
             compress_chunk             
----------------------------------------
 _timescaledb_internal._hyper_1_1_chunk
 _timescaledb_internal._hyper_1_2_chunk
 _timescaledb_internal._hyper_1_3_chunk

VACUUM ANALYZE testtable;
-- Vectorized aggregation possible
SELECT sum(segment_by_value) FROM testtable;
  sum   
--------
 304695

:EXPLAIN
SELECT sum(segment_by_value) FROM testtable;
--- QUERY PLAN ---
 Finalize Aggregate
   Output: sum(testtable.segment_by_value)
   ->  Append
         ->  Custom Scan (VectorAgg)
               Output: (PARTIAL sum(_hyper_1_1_chunk.segment_by_value))
               Grouping Policy: all compressed batches
               ->  Custom Scan (ColumnarScan) on _timescaledb_internal._hyper_1_1_chunk
                     Output: _hyper_1_1_chunk.segment_by_value
                     ->  Seq Scan on _timescaledb_internal._hyper_1_1_chunk_compressed
                           Output: _hyper_1_1_chunk_compressed._ts_meta_count, _hyper_1_1_chunk_compressed.segment_by_value, _hyper_1_1_chunk_compressed._ts_meta_min_1, _hyper_1_1_chunk_compressed._ts_meta_max_1, _hyper_1_1_chunk_compressed._ts_meta_v2_first_time, _hyper_1_1_chunk_compressed._ts_meta_v2_last_time, _hyper_1_1_chunk_compressed."time", _hyper_1_1_chunk_compressed.int_value, _hyper_1_1_chunk_compressed.float_value
         ->  Custom Scan (VectorAgg)
               Output: (PARTIAL sum(_hyper_1_2_chunk.segment_by_value))
               Grouping Policy: all compressed batches
               ->  Custom Scan (ColumnarScan) on _timescaledb_internal._hyper_1_2_chunk
                     Output: _hyper_1_2_chunk.segment_by_value
                     ->  Seq Scan on _timescaledb_internal._hyper_1_2_chunk_compressed
                           Output: _hyper_1_2_chunk_compressed._ts_meta_count, _hyper_1_2_chunk_compressed.segment_by_value, _hyper_1_2_chunk_compressed._ts_meta_min_1, _hyper_1_2_chunk_compressed._ts_meta_max_1, _hyper_1_2_chunk_compressed._ts_meta_v2_first_time, _hyper_1_2_chunk_compressed._ts_meta_v2_last_time, _hyper_1_2_chunk_compressed."time", _hyper_1_2_chunk_compressed.int_value, _hyper_1_2_chunk_compressed.float_value
         ->  Custom Scan (VectorAgg)
               Output: (PARTIAL sum(_hyper_1_3_chunk.segment_by_value))
               Grouping Policy: all compressed batches
               ->  Custom Scan (ColumnarScan) on _timescaledb_internal._hyper_1_3_chunk
                     Output: _hyper_1_3_chunk.segment_by_value
                     ->  Seq Scan on _timescaledb_internal._hyper_1_3_chunk_compressed
                           Output: _hyper_1_3_chunk_compressed._ts_meta_count, _hyper_1_3_chunk_compressed.segment_by_value, _hyper_1_3_chunk_compressed._ts_meta_min_1, _hyper_1_3_chunk_compressed._ts_meta_max_1, _hyper_1_3_chunk_compressed._ts_meta_v2_first_time, _hyper_1_3_chunk_compressed._ts_meta_v2_last_time, _hyper_1_3_chunk_compressed."time", _hyper_1_3_chunk_compressed.int_value, _hyper_1_3_chunk_compressed.float_value
         ->  Partial Aggregate
