-- Invalid configurations should be rejected
\set ON_ERROR_STOP 0
\set VERBOSITY default
CALL refresh_continuous_aggregate(
    'conditions_by_day', NULL, NULL,
    options => '{"max_batches_per_execution": -1}'::jsonb);
