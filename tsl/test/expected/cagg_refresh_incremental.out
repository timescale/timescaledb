RESET client_min_messages;
LOG:  statement: RESET client_min_messages;
CALL refresh_continuous_aggregate(
    'conditions_by_day_atomic_refresh',
    '2025-03-11 00:00:00+00'::timestamptz - INTERVAL '15 days',
