SELECT t, (i % 5), random()
FROM generate_series('2024-01-01'::timestamptz, '2024-01-02'::timestamptz, '1 minute') t,
     generate_series(1, 5) i;
SELECT * FROM _timescaledb_catalog.compression_settings;
                  relid                   |                  compress_relid                  |  segmentby  | orderby | orderby_desc | orderby_nullsfirst |                            index                            
------------------------------------------+--------------------------------------------------+-------------+---------+--------------+--------------------+-------------------------------------------------------------
 test_second_insert                       |                                                  |             |         |              |                    | 
 _timescaledb_internal._hyper_21_30_chunk | _timescaledb_internal.compress_hyper_22_32_chunk | {device_id} | {time}  | {t}          | {t}                | [{"type": "minmax", "column": "time", "source": "orderby"}]

INSERT INTO test_second_insert
SELECT t, (i % 5), random()
FROM generate_series('2024-01-02'::timestamptz, '2024-01-03'::timestamptz, '1 minute') t,
