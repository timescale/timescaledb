CREATE TABLE int2_crosstype(ts int NOT NULL, i2 smallint, i4 int)
WITH (tsdb.hypertable, tsdb.partition_column = 'ts',
    tsdb.compress, tsdb.compress_orderby = 'ts', tsdb.compress_index = 'bloom(i2), bloom(i2, i4)')
;
