-- Test the integration of the compression and observability features
CREATE TABLE t(ts timestamptz, a int, b int, c int, seg int);
SELECT create_hypertable('t', by_range('ts', interval '1 day'));
 create_hypertable 
-------------------
 (1,t)

-- Initial config: bloom(a,b)
ALTER TABLE t SET (
    timescaledb.compress,
    timescaledb.compress_segmentby = 'seg',
    timescaledb.compress_orderby = 'ts',
    timescaledb.compress_index = 'bloom(a,b)'
);
INSERT INTO t
SELECT ts, (i % 10), (i % 5), (i % 3), 1
FROM generate_series('2024-01-01'::timestamptz, '2024-01-03', interval '1 hour') ts,
     generate_series(1, 100) i;
SELECT compress_chunk(c) FROM show_chunks('t') c;
             compress_chunk             
----------------------------------------
 _timescaledb_internal._hyper_1_1_chunk
 _timescaledb_internal._hyper_1_2_chunk
 _timescaledb_internal._hyper_1_3_chunk

-- omit timing information from the output
SELECT key_id,key_name,description,total_count FROM _timescaledb_functions.observ_keys();
 key_id |           key_name            |                   description                   | total_count 
--------+-------------------------------+-------------------------------------------------+-------------
      0 | unused                        | Unused key                                      |           0
      1 | event_type                    | Type of event                                   |           6
      2 | relid                         | Relation ID                                     |           6
      3 | compress_relid                | Compressed Relation ID                          |           6
      4 | agg_count                     | Number of aggregated observations               |           6
      5 | agg_start                     | Aggregation start time                          |           6
      6 | agg_end                       | Aggregation end time                            |           6
      7 | batch_rows_sum                | Sum of rows per batch                           |           3
      8 | batch_rows_min                | Min rows per batch                              |           3
      9 | batch_rows_max                | Max rows per batch                              |           3
     10 | batch_rows_avg                | Average rows per batch                          |           3
     11 | batch_rows_stddev             | Standard deviation of rows per batch            |           3
     12 | batch_bytes_sum               | Sum of bytes per batch                          |           3
     13 | batch_bytes_min               | Min bytes per batch                             |           3
     14 | batch_bytes_max               | Max bytes per batch                             |           3
     15 | batch_bytes_avg               | Average bytes per batch                         |           3
     16 | batch_bytes_stddev            | Standard deviation of bytes per batch           |           3
     17 | hypertable_id                 | Hypertable ID                                   |           0
     18 | is_columnar_scan              | Whether the event is from a columnar scan       |           0
     19 | cmd_type                      | Command type (the value of the CmdType enum)    |           0
     20 | batches_deleted               | Number of batches deleted without decompression |           0
     21 | batches_decompressed          | Number of batches decompressed                  |           0
     22 | batches_scanned               | Number of batches scanned                       |           0
     23 | batches_checked_by_bloom      | Number of batches checked by bloom filter       |           0
     24 | batches_pruned_by_bloom       | Number of batches pruned by bloom filter        |           0
     25 | batches_without_bloom         | Number of batches without bloom filter          |           0
     26 | bloom_false_positives         | Number of bloom filter false positives          |           0
     27 | decompressed_tuples           | Number of tuples decompressed                   |           0
     28 | deleted_tuples                | Number of tuples deleted by direct batch delete |           0
     29 | batches_filtered_compressed   | Number of batches filtered by compression       |           0
     30 | batches_filtered_decompressed | Number of batches filtered by decompression     |           0

