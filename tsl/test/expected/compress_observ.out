-- Test DELETE stats
BEGIN;
DELETE FROM t WHERE a % 19 = 2;
ROLLBACK;
SELECT dense_rank() OVER (ORDER BY event_id) AS event_num,
       payload - ARRAY['agg_start', 'agg_end', 'relid', 'compress_relid'] AS filtered_payload
FROM _timescaledb_functions.observ_log_events(filter => '{"event_type": 2, "cmd_type": 4}');
 event_num |                                                                                      filtered_payload                                                                                      
-----------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
         1 | {"cmd_type": 4, "agg_count": 2, "event_type": 2, "batch_rows_avg": 800, "batch_rows_max": 1000, "batch_rows_min": 600, "batch_rows_sum": 1600, "batch_rows_stddev": 200}
         2 | {"cmd_type": 4, "agg_count": 8, "event_type": 2, "batch_bytes_avg": 414, "batch_bytes_max": 748, "batch_bytes_min": 188, "batch_bytes_sum": 3312, "batch_bytes_stddev": 168.463645929916}
         3 | {"cmd_type": 4, "agg_count": 3, "event_type": 2, "batch_rows_avg": 800, "batch_rows_max": 1000, "batch_rows_min": 400, "batch_rows_sum": 2400, "batch_rows_stddev": 282.842712474619}
         4 | {"cmd_type": 4, "agg_count": 12, "event_type": 2, "batch_bytes_avg": 414, "batch_bytes_max": 748, "batch_bytes_min": 132, "batch_bytes_sum": 4968, "batch_bytes_stddev": 196.533288104925}
         5 | {"cmd_type": 4, "agg_count": 1, "event_type": 2, "batch_rows_avg": 900, "batch_rows_max": 900, "batch_rows_min": 900, "batch_rows_sum": 900, "batch_rows_stddev": 0}
         6 | {"cmd_type": 4, "agg_count": 4, "event_type": 2, "batch_bytes_avg": 460, "batch_bytes_max": 668, "batch_bytes_min": 260, "batch_bytes_sum": 1840, "batch_bytes_stddev": 150.412765415705}

SELECT dense_rank() OVER (ORDER BY event_id) AS event_num,
       payload - ARRAY['agg_start', 'agg_end', 'relid', 'compress_relid'] AS filtered_payload
FROM _timescaledb_functions.observ_log_events(filter => '{"event_type": 3, "cmd_type": 4}');
