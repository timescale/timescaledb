step K1_terminate: 
    DO $$
    DECLARE
        target_pid int;
    BEGIN
        SELECT pid INTO target_pid FROM cancelpid;
        PERFORM pg_terminate_backend(target_pid);
        LOOP
            EXIT WHEN NOT EXISTS (
                SELECT 1 FROM pg_stat_activity WHERE pid = target_pid
            );
            PERFORM pg_sleep(0.05);
        END LOOP;
    END;
    $$;

