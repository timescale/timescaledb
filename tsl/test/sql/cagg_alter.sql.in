-- Tests for add_continuous_aggregate_column function

SET ROLE :ROLE_DEFAULT_PERM_USER;

-- Create test hypertable
CREATE TABLE test_ht (
    time TIMESTAMPTZ NOT NULL,
    device_id INTEGER NOT NULL,
    value DOUBLE PRECISION,
    extra TEXT,
    location TEXT
);

SELECT create_hypertable('test_ht', 'time');

-- Insert some test data
INSERT INTO test_ht VALUES
    ('2020-01-01 00:00:00', 1, 10.0, 'extra1', 'loc1'),
    ('2020-01-01 01:00:00', 1, 20.0, 'extra2', 'loc1'),
    ('2020-01-01 02:00:00', 2, 30.0, 'extra3', 'loc2'),
    ('2020-01-02 00:00:00', 1, 15.0, 'extra4', 'loc1'),
    ('2020-01-02 01:00:00', 2, 25.0, 'extra5', 'loc2');

-- Create a simple continuous aggregate (materialized-only mode)
CREATE MATERIALIZED VIEW test_cagg_mat_only
    WITH (timescaledb.continuous, timescaledb.materialized_only=true)
AS SELECT
    time_bucket('1 day', time) AS bucket,
    device_id,
    avg(value) AS avg_value
FROM test_ht
GROUP BY 1, 2
WITH NO DATA;

-- Create a real-time continuous aggregate
CREATE MATERIALIZED VIEW test_cagg_realtime
    WITH (timescaledb.continuous, timescaledb.materialized_only=false)
AS SELECT
    time_bucket('1 day', time) AS bucket,
    device_id,
    avg(value) AS avg_value
FROM test_ht
GROUP BY 1, 2
WITH NO DATA;

-- Show initial state
SELECT user_view_name, partial_view_name, direct_view_name
FROM _timescaledb_catalog.continuous_agg
WHERE user_view_name IN ('test_cagg_mat_only', 'test_cagg_realtime')
ORDER BY user_view_name;

-- Add column to materialized-only CAgg
SELECT add_continuous_aggregate_column('test_cagg_mat_only', 'extra');

-- Verify the column was added
\d+ test_cagg_mat_only

-- Add column to real-time CAgg
SELECT add_continuous_aggregate_column('test_cagg_realtime', 'location');

-- Verify the column was added
\d+ test_cagg_realtime

-- Error - column doesn't exist
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('test_cagg_mat_only', 'nonexistent_column');
\set ON_ERROR_STOP 1

-- Error - column already exists in CA
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('test_cagg_mat_only', 'device_id');
\set ON_ERROR_STOP 1

-- Error - column already added
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('test_cagg_mat_only', 'extra');
\set ON_ERROR_STOP 1

-- if_not_exists=true should not error
SELECT add_continuous_aggregate_column('test_cagg_mat_only', 'extra', true);
SELECT add_continuous_aggregate_column('test_cagg_mat_only', 'device_id', true);

-- Refresh and verify data
CALL refresh_continuous_aggregate('test_cagg_mat_only', NULL, NULL);
CALL refresh_continuous_aggregate('test_cagg_realtime', NULL, NULL);

-- Check data in materialized-only CA
SELECT * FROM test_cagg_mat_only ORDER BY bucket, device_id;

-- Check data in real-time CA
SELECT * FROM test_cagg_realtime ORDER BY bucket, device_id;

-- Add another column and refresh again
SELECT add_continuous_aggregate_column('test_cagg_mat_only', 'location');

-- Insert new data
INSERT INTO test_ht VALUES
    ('2020-01-03 00:00:00', 1, 35.0, 'extra6', 'loc3'),
    ('2020-01-03 01:00:00', 2, 45.0, 'extra7', 'loc3');

CALL refresh_continuous_aggregate('test_cagg_mat_only', NULL, NULL);

-- New data should have the location column populated
SELECT * FROM test_cagg_mat_only ORDER BY bucket, device_id;

-- Error - not a continuous aggregate
CREATE TABLE regular_table (id INT, data TEXT);
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('regular_table', 'data');
\set ON_ERROR_STOP 1
DROP TABLE regular_table;

-- Hierarchical continuous aggregate (CAgg on CAgg)
-- Create a second-level CAgg on top of test_cagg_mat_only
CREATE MATERIALIZED VIEW test_cagg_level2
    WITH (timescaledb.continuous, timescaledb.materialized_only=true)
AS SELECT
    time_bucket('7 days', bucket) AS bucket,
    device_id,
    avg(avg_value) AS avg_value
FROM test_cagg_mat_only
GROUP BY 1, 2
WITH NO DATA;

-- Create a third-level CAgg on top of test_cagg_level2
CREATE MATERIALIZED VIEW test_cagg_level3
    WITH (timescaledb.continuous, timescaledb.materialized_only=true)
AS SELECT
    time_bucket('14 days', bucket) AS bucket,
    device_id,
    avg(avg_value) AS avg_value
FROM test_cagg_level2
GROUP BY 1, 2
WITH NO DATA;

-- Refresh all levels
CALL refresh_continuous_aggregate('test_cagg_level2', NULL, NULL);
CALL refresh_continuous_aggregate('test_cagg_level3', NULL, NULL);

-- Show initial state
SELECT * FROM test_cagg_level2 ORDER BY bucket, device_id;
SELECT * FROM test_cagg_level3 ORDER BY bucket, device_id;

-- Error - column doesn't exist
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('test_cagg_level2', 'nonexistent_column');
\set ON_ERROR_STOP 1

-- Add column to second-level CAgg (column exists in parent CAgg)
SELECT add_continuous_aggregate_column('test_cagg_level2', 'extra');

-- Error - column already exists
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('test_cagg_level2', 'extra');
\set ON_ERROR_STOP 1

-- if_not_exists=true should not error
SELECT add_continuous_aggregate_column('test_cagg_level2', 'extra', true);

-- Verify the column was added
\d+ test_cagg_level2

-- Refresh and check data
CALL refresh_continuous_aggregate('test_cagg_level2', NULL, NULL);
SELECT * FROM test_cagg_level2 ORDER BY bucket, device_id;

-- Add same column to third-level CAgg (now exists in second-level)
SELECT add_continuous_aggregate_column('test_cagg_level3', 'extra');

-- Verify the column was added
\d+ test_cagg_level3

-- Refresh and check data
CALL refresh_continuous_aggregate('test_cagg_level3', NULL, NULL);
SELECT * FROM test_cagg_level3 ORDER BY bucket, device_id;

-- Cleanup materialized-only hierarchical CAggs
DROP MATERIALIZED VIEW test_cagg_level3;
DROP MATERIALIZED VIEW test_cagg_level2;

-- Hierarchical continuous aggregate with real-time mode
-- Create a second-level real-time CAgg on top of test_cagg_realtime
CREATE MATERIALIZED VIEW test_cagg_realtime_level2
    WITH (timescaledb.continuous, timescaledb.materialized_only=false)
AS SELECT
    time_bucket('7 days', bucket) AS bucket,
    device_id,
    avg(avg_value) AS avg_value
FROM test_cagg_realtime
GROUP BY 1, 2
WITH NO DATA;

-- Create a third-level real-time CAgg on top of test_cagg_realtime_level2
CREATE MATERIALIZED VIEW test_cagg_realtime_level3
    WITH (timescaledb.continuous, timescaledb.materialized_only=false)
AS SELECT
    time_bucket('14 days', bucket) AS bucket,
    device_id,
    avg(avg_value) AS avg_value
FROM test_cagg_realtime_level2
GROUP BY 1, 2
WITH NO DATA;

-- Refresh all levels
CALL refresh_continuous_aggregate('test_cagg_realtime_level2', NULL, NULL);
CALL refresh_continuous_aggregate('test_cagg_realtime_level3', NULL, NULL);

-- Show initial state
SELECT * FROM test_cagg_realtime_level2 ORDER BY bucket, device_id;
SELECT * FROM test_cagg_realtime_level3 ORDER BY bucket, device_id;

-- Error - column doesn't exist
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('test_cagg_realtime_level2', 'nonexistent_column');
\set ON_ERROR_STOP 1

-- Add column to second-level real-time CAgg (column exists in parent CAgg)
SELECT add_continuous_aggregate_column('test_cagg_realtime_level2', 'location');

-- Error - column already exists
\set ON_ERROR_STOP 0
SELECT add_continuous_aggregate_column('test_cagg_realtime_level2', 'location');
\set ON_ERROR_STOP 1

-- if_not_exists=true should not error
SELECT add_continuous_aggregate_column('test_cagg_realtime_level2', 'location', true);

-- Verify the column was added
\d+ test_cagg_realtime_level2

-- Refresh and check data
CALL refresh_continuous_aggregate('test_cagg_realtime_level2', NULL, NULL);
SELECT * FROM test_cagg_realtime_level2 ORDER BY bucket, device_id;

-- Add same column to third-level real-time CAgg (now exists in second-level)
SELECT add_continuous_aggregate_column('test_cagg_realtime_level3', 'location');

-- Verify the column was added
\d+ test_cagg_realtime_level3

-- Refresh and check data
CALL refresh_continuous_aggregate('test_cagg_realtime_level3', NULL, NULL);
SELECT * FROM test_cagg_realtime_level3 ORDER BY bucket, device_id;

-- Insert more data to test real-time aggregation
INSERT INTO test_ht VALUES
    ('2020-01-04 00:00:00', 1, 40.0, 'extra8', 'loc4'),
    ('2020-01-04 01:00:00', 2, 50.0, 'extra9', 'loc4');

-- Query real-time hierarchical CAggs (should include new data without refresh)
SELECT * FROM test_cagg_realtime_level2 ORDER BY bucket, device_id;
SELECT * FROM test_cagg_realtime_level3 ORDER BY bucket, device_id;

-- Cleanup
DROP MATERIALIZED VIEW test_cagg_realtime_level3;
DROP MATERIALIZED VIEW test_cagg_realtime_level2;
DROP MATERIALIZED VIEW test_cagg_mat_only;
DROP MATERIALIZED VIEW test_cagg_realtime;
DROP TABLE test_ht;
