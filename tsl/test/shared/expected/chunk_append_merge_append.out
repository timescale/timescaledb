-- Make partially compressed
INSERT INTO ht_space_partial
SELECT time, device, device * 0.1
FROM generate_series('2020-01-01'::timestamptz, '2020-01-14'::timestamptz, '6 hour') time,
     generate_series(1,4) device;
ANALYZE ht_space_partial;
-- Both space partitions AND partial compression per time slice
:PREFIX SELECT * FROM ht_space_partial ORDER BY time LIMIT 10;
--- QUERY PLAN ---
 Limit
   ->  Custom Scan (ChunkAppend) on ht_space_partial
         Order: ht_space_partial."time"
         ->  Merge Append
               Sort Key: ht_space_partial."time"
               ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk
                     ->  Sort
                           Sort Key: compress_hyper_X_X_chunk._ts_meta_min_1
                           ->  Seq Scan on compress_hyper_X_X_chunk
               ->  Index Scan Backward using _hyper_X_X_chunk_ht_space_partial_time_idx on _hyper_X_X_chunk
               ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk
                     ->  Sort
                           Sort Key: compress_hyper_X_X_chunk._ts_meta_min_1
                           ->  Seq Scan on compress_hyper_X_X_chunk
               ->  Index Scan Backward using _hyper_X_X_chunk_ht_space_partial_time_idx on _hyper_X_X_chunk
         ->  Merge Append
               Sort Key: ht_space_partial."time"
               ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk
                     ->  Sort
                           Sort Key: compress_hyper_X_X_chunk._ts_meta_min_1
                           ->  Seq Scan on compress_hyper_X_X_chunk
               ->  Index Scan Backward using _hyper_X_X_chunk_ht_space_partial_time_idx on _hyper_X_X_chunk
               ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk
                     ->  Sort
                           Sort Key: compress_hyper_X_X_chunk._ts_meta_min_1
                           ->  Seq Scan on compress_hyper_X_X_chunk
               ->  Index Scan Backward using _hyper_X_X_chunk_ht_space_partial_time_idx on _hyper_X_X_chunk
         ->  Merge Append
               Sort Key: ht_space_partial."time"
               ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk
                     ->  Sort
                           Sort Key: compress_hyper_X_X_chunk._ts_meta_min_1
                           ->  Seq Scan on compress_hyper_X_X_chunk
               ->  Index Scan Backward using _hyper_X_X_chunk_ht_space_partial_time_idx on _hyper_X_X_chunk
               ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk
                     ->  Sort
                           Sort Key: compress_hyper_X_X_chunk._ts_meta_min_1
                           ->  Seq Scan on compress_hyper_X_X_chunk
               ->  Index Scan Backward using _hyper_X_X_chunk_ht_space_partial_time_idx on _hyper_X_X_chunk

SELECT count(*) FROM ht_space_partial;
