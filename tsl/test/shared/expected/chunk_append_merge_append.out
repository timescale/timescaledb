-- Tests for parameterized ChunkAppend in ordered mode crashing when creating
-- a MergeAppend because the latter doesn't support parameterization in
-- Postgres. We cover several code paths where this can happen (space
-- partitioning and partially compressed chunks).
\set PREFIX 'EXPLAIN (costs off)'
SET max_parallel_workers_per_gather = 0;
SET enable_material = off;
SET enable_seqscan = off;
SET enable_hashjoin = off;
SET enable_mergejoin = off;
:PREFIX
SELECT m.time, m.device_id, m.v0
FROM devices d
JOIN metrics_compressed m ON m.device_id = d.device_id
WHERE m.time < now()
ORDER BY m.time;
--- QUERY PLAN ---
 Sort
   Sort Key: m."time"
   ->  Nested Loop
         ->  Seq Scan on devices d
         ->  Custom Scan (ConstraintAwareAppend)
               Hypertable: metrics_compressed
               Chunks excluded during startup: 0
               ->  Append
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_1
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Index Scan using _hyper_X_X_chunk_metrics_compressed_device_id_time_idx on _hyper_X_X_chunk m_1
                           Index Cond: ((device_id = d.device_id) AND ("time" < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_2
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_3
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))

:PREFIX
SELECT m.time, m.device_id, m.v0
FROM devices d
JOIN metrics_space_compressed m ON m.device_id = d.device_id
WHERE m.time < now()
ORDER BY m.time;
--- QUERY PLAN ---
 Sort
   Sort Key: m."time"
   ->  Nested Loop
         ->  Seq Scan on devices d
         ->  Custom Scan (ConstraintAwareAppend)
               Hypertable: metrics_space_compressed
               Chunks excluded during startup: 0
               ->  Append
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_1
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_2
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_3
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_4
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_5
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_6
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_7
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_8
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))
                     ->  Custom Scan (ColumnarScan) on _hyper_X_X_chunk m_9
                           Vectorized Filter: ("time" < now())
                           ->  Index Scan using compress_hyper_X_X_chunk_device_id__ts_meta_min_1__ts_meta_idx on compress_hyper_X_X_chunk
                                 Index Cond: ((device_id = d.device_id) AND (_ts_meta_min_1 < now()))

RESET enable_material;
RESET enable_seqscan;
RESET enable_hashjoin;
RESET enable_mergejoin;
RESET max_parallel_workers_per_gather;
