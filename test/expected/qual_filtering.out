-- Test qual filtering optimization (timescaledb.enable_qual_filtering).
-- When a chunk is fully covered by the query's dimension restrictions,
-- the planner can remove redundant quals from that chunk's scan.
CREATE TABLE qual_filter_tz(
    id serial,
    ts timestamptz NOT NULL
);
SELECT create_hypertable('qual_filter_tz', 'ts',
    chunk_time_interval => INTERVAL '7 days');
      create_hypertable      
-----------------------------
 (1,public,qual_filter_tz,t)

INSERT INTO qual_filter_tz(ts)
SELECT generate_series(
    '2026-01-01 00:00:00+00'::timestamptz,
    '2026-03-10 00:00:00+00'::timestamptz,
    '1 day'::interval
);
-- Without ::date cast (same-type comparison, immutable).
SELECT count(*) FROM qual_filter_tz
WHERE ts >= '2026-02-01' AND ts < '2026-03-01';
 count 
-------
    28

-- With ::date cast (cross-type STABLE operator).
-- Must return the same count.
SELECT count(*) FROM qual_filter_tz
WHERE ts >= '2026-02-01' AND ts < '2026-03-01'::date;
 count 
-------
    28

-- Verify with qual filtering off for comparison.
SET timescaledb.enable_qual_filtering = off;
SELECT count(*) FROM qual_filter_tz
WHERE ts >= '2026-02-01' AND ts < '2026-03-01'::date;
 count 
-------
    28

RESET timescaledb.enable_qual_filtering;
-- Also test with ::timestamp cast (another cross-type, but immutable
-- for timestamp vs timestamptz since both store UTC microseconds).
SELECT count(*) FROM qual_filter_tz
WHERE ts >= '2026-02-01' AND ts < '2026-03-01'::timestamp;
 count 
-------
    28

-- Test with date column and ::timestamp cast on the constant.
CREATE TABLE qual_filter_date(
    id serial,
    d date NOT NULL
);
SELECT create_hypertable('qual_filter_date', 'd',
    chunk_time_interval => INTERVAL '7 days');
       create_hypertable       
-------------------------------
 (2,public,qual_filter_date,t)

INSERT INTO qual_filter_date(d)
SELECT generate_series('2026-01-01'::date, '2026-03-10'::date, '1 day');
-- date column with ::timestamp constant -- same-type after implicit cast.
SELECT count(*) FROM qual_filter_date
WHERE d >= '2026-02-01' AND d < '2026-03-01'::timestamp;
 count 
-------
    28

SET timescaledb.enable_qual_filtering = off;
SELECT count(*) FROM qual_filter_date
WHERE d >= '2026-02-01' AND d < '2026-03-01'::timestamp;
 count 
-------
    28

RESET timescaledb.enable_qual_filtering;
-- Cleanup
DROP TABLE qual_filter_tz;
DROP TABLE qual_filter_date;
-- Additional qual filtering divergence tests.
-- filter_baserestrictions must not strip quals that HRI would reject.
-- Each test below targets a specific HRI rejection path.
CREATE TABLE qual_filter_ops(ts timestamptz NOT NULL, val int);
SELECT create_hypertable('qual_filter_ops', 'ts',
    chunk_time_interval => INTERVAL '7 days');
      create_hypertable       
------------------------------
 (3,public,qual_filter_ops,t)

INSERT INTO qual_filter_ops
SELECT t, extract(day from t)::int
FROM generate_series(
    '2000-01-01'::timestamptz,
    '2000-01-28'::timestamptz,
    '1 day') t;
-- Baseline: 14 rows in [Jan 8, Jan 22)
SELECT count(*) FROM qual_filter_ops
WHERE ts >= '2000-01-08' AND ts < '2000-01-22';
 count 
-------
    14

-- 1) Operator not in btree opfamily.
-- HRI rejects at op_in_opfamily. Use plpgsql to prevent inlining.
CREATE FUNCTION qf_tstz_lt(timestamptz, timestamptz) RETURNS bool
    AS $$ BEGIN RETURN $1 < $2; END $$ LANGUAGE plpgsql IMMUTABLE STRICT;
CREATE OPERATOR <<< (LEFTARG = timestamptz, RIGHTARG = timestamptz,
    FUNCTION = qf_tstz_lt);
SELECT count(*) FROM qual_filter_ops
WHERE ts >= '2000-01-08' AND ts <<< '2000-01-22'::timestamptz;
 count 
-------
    14

SET timescaledb.enable_qual_filtering = off;
SELECT count(*) FROM qual_filter_ops
WHERE ts >= '2000-01-08' AND ts <<< '2000-01-22'::timestamptz;
 count 
-------
    14

RESET timescaledb.enable_qual_filtering;
-- 2) Non-strict operator.
-- HRI rejects at op_strict. Use plpgsql to prevent inlining.
CREATE FUNCTION qf_tstz_lt_nonstrict(timestamptz, timestamptz) RETURNS bool
    AS $$ BEGIN RETURN $1 < $2; END $$ LANGUAGE plpgsql IMMUTABLE;
CREATE OPERATOR <<!>> (LEFTARG = timestamptz, RIGHTARG = timestamptz,
    FUNCTION = qf_tstz_lt_nonstrict);
SELECT count(*) FROM qual_filter_ops
WHERE ts >= '2000-01-08' AND ts <<!>> '2000-01-22'::timestamptz;
 count 
-------
    14

SET timescaledb.enable_qual_filtering = off;
SELECT count(*) FROM qual_filter_ops
WHERE ts >= '2000-01-08' AND ts <<!>> '2000-01-22'::timestamptz;
 count 
-------
    14

RESET timescaledb.enable_qual_filtering;
-- 3) Parameterized query (generic plan).
-- HRI rejects because eval_const_expressions cannot fold a Param to Const.
SET plan_cache_mode = force_generic_plan;
PREPARE qf_param(timestamptz) AS
    SELECT count(*) FROM qual_filter_ops
    WHERE ts >= '2000-01-08' AND ts < $1;
EXECUTE qf_param('2000-01-22');
 count 
-------
    14

DEALLOCATE qf_param;
SET timescaledb.enable_qual_filtering = off;
PREPARE qf_param(timestamptz) AS
    SELECT count(*) FROM qual_filter_ops
    WHERE ts >= '2000-01-08' AND ts < $1;
EXECUTE qf_param('2000-01-22');
 count 
-------
    14

DEALLOCATE qf_param;
RESET timescaledb.enable_qual_filtering;
RESET plan_cache_mode;
DROP TABLE qual_filter_ops;
